# ─────────────────────────────────────────────────────────────
# CAREME — Environment Variables (copy this to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Supabase PostgreSQL connection string
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="<your-strong-random-secret-at-least-32-chars>"
# Set to your production domain in production
NEXTAUTH_URL="https://yourapp.vercel.app"

# ── Stripe ────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
# Get from https://dashboard.stripe.com/webhooks (after creating webhook)
# Webhook endpoint: https://yourapp.vercel.app/api/webhooks/stripe
# Events to listen: checkout.session.completed
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Supabase ──────────────────────────────────────────────────
# Get from https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
# WARNING: Service role key has full DB access. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Email (Resend) ────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_..."
# The "from" address for transactional emails (must be a verified domain)
EMAIL_FROM="Careme <noreply@yourdomain.com>"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourapp.vercel.app"
